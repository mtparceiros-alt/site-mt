        IDX["index.html"]
        PROP["properties.html"]
        CONT["contact.html"]
        DET["property-details.html"]
        
        EMPJS --> IDX
        EMPJS --> PROP
        
        IDX --> SIM["Simulador MCMV"]
        IDX --> MAP1["Mapa Leaflet"]
        PROP --> MAP2["Mapa Leaflet"]
        PROP --> GRID["Grid Isotope + Filtros"]
        
        SIM --> CALC["simulator-core.js<br/>(calculateMCMV)"]
        CALC --> RES["Resultados na Tela"]
        RES --> XLSX["Download .xlsx<br/>(ExcelJS)"]
    end

    subgraph Backend["☁️ Backend / CRM"]
        GAS["Google Apps Script<br/>(Webhook)"]
        FS["FormSubmit<br/>(Email Backup)"]
        WA["WhatsApp<br/>(Link Direto)"]
        SHEET["Planilha Mestre<br/>(Google Sheets)"]
        
        SIM -->|POST no-cors| GAS
        SIM -->|POST no-cors| FS
        SIM -->|Link gerado| WA
        
        CONT -->|POST| GAS
        CONT -->|POST| FS
        
        GAS --> SHEET
    end
```

